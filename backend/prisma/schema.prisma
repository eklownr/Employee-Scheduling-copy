generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql" 
}

// Användare med roll (employer/employee)
model User {
  id              String          @id @default(uuid()) // FIXME: seq id, not UUID, easy to read and use
  email           String          @unique
  password        String
  role            Role            @default(EMPLOYEE)
  firstName       String?
  lastName        String?
  loginCode       String?         @unique // För registrering av employees
  availabilities  Availability[]
  scheduleEntries ScheduleEntry[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@map("users")
}

enum Role {
  EMPLOYEE
  EMPLOYER
}
//TODO: Enum occupation: runner,waiter, dishwasher, chef

// Skift (morning, afternoon, night)
enum Shift {
  MORNING
  AFTERNOON
  NIGHT
}

// Tillgänglighet: Anställd anger önskade skift per dag
model Availability {
  id        String   @id @default(uuid()) /// FIXME: seq id, not UUID, easy to read and use
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  date      DateTime // Datum för tillgänglighet
  shift     Shift
  createdAt DateTime @default(now())

  @@unique([userId, date, shift]) // Unik kombination
  @@map("availabilities")
}

// Schemapost: Vem jobbar vilket skift på vilken dag
model ScheduleEntry {
  id         String   @id @default(uuid()) // FIXME: seq id, not UUID, easy to read and use
  user       User     @relation(fields: [userId], references: [id])
  userId     String
  date       DateTime // Arbetsdag
  shift      Shift
  assignedBy String?  // FK till User (employer som tilldelade)
  createdAt  DateTime @default(now())

  @@unique([userId, date, shift]) // Hindra dubbla skift
  @@map("schedule_entries")
}

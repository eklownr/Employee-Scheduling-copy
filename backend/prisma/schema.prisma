generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql" 
}

// Användare med roll (employer/employee)
model User {
  id              Int          @id @default(autoincrement())
  email           String          @unique
  password        String
  role            Role            @default(EMPLOYEE)
  Occupation      Occupation      @default(RUNNER)
  firstName       String?
  lastName        String?
  loginCode       String?         @unique // För registrering av employees
  availabilities  Availability[]
  scheduleEntries ScheduleEntry[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@map("users")
}

enum Role {
  EMPLOYEE
  EMPLOYER
}

enum Occupation {
  RUNNER
  WAITER
  DISHWASHER
  CHEF
}

// Skift (morning, afternoon, night)
enum Shift {
  MORNING
  AFTERNOON
  NIGHT
}

// Tillgänglighet: Anställd anger önskade skift per dag
model Availability {
  id        Int      @id @default(autoincrement())
  user      User     @relation(fields: [userId], references: [id])
  userId    Int
  dayOfWeek DayOfWeek // Datum för tillgänglighet
  shift     Shift
  createdAt DateTime @default(now())

  @@unique([userId, dayOfWeek, shift]) // Unik kombination
  @@map("availabilities")
}

// Schemapost: Vem jobbar vilket skift på vilken dag
model ScheduleEntry {
  id         Int      @id @default(autoincrement())
  user       User     @relation(fields: [userId], references: [id])
  userId     Int
  date       DateTime // Arbetsdag
  shift      Shift
  assignedBy String?  // FK till User (employer som tilldelade)
  createdAt  DateTime @default(now())

  @@unique([userId, date, shift]) // Hindra dubbla skift
  @@map("schedule_entries")
}

enum DayOfWeek {
  Mon
  Tue
  Wed
  Thu
  Fri
  Sat
  Sun
}
